# Countrify — environment variables
# Copiar a .env.local y rellenar con valores reales. NUNCA commitear .env.local.

# === AWS ===
AWS_REGION=us-east-1

# === Servidor ===
PORT=3000
HOSTNAME=0.0.0.0
APP_SESSION_SECRET=

# === RDS (Postgres) ===
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=require

# === Cognito ===
AWS_COGNITO_REGION=us-east-1
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=

# === S3 ===
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=

# === Web Push ===
VAPID_MAILTO=mailto:admin@countrify.com.ar
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# === OpenRouter (IA backoffice) ===
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=

# === Supabase legacy (a remover progresivamente) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
