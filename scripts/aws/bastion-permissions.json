{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadMigrationSql",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::countrify-prod-assets/_temp/*"
    },
    {
      "Sid": "ReadTempAdminPassword",
      "Effect": "Allow",
      "Action": ["secretsmanager:GetSecretValue"],
      "Resource": "arn:aws:secretsmanager:us-east-1:351885857894:secret:countrify/_temp/migration-admin-password-*"
    }
  ]
}
