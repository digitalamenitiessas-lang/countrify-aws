{
  "family": "countrify-prod-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::351885857894:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::351885857894:role/countrify-prod-task-role",
  "containerDefinitions": [
    {
      "name": "countrify-web",
      "image": "351885857894.dkr.ecr.us-east-1.amazonaws.com/countrify/countrify-web-prod:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "AWS_COGNITO_REGION", "value": "us-east-1" },
        { "name": "AWS_COGNITO_USER_POOL_ID", "value": "us-east-1_qJ3dgY94K" },
        { "name": "AWS_COGNITO_CLIENT_ID", "value": "1j352cuughs2f1ustrf0i0rma8" },
        { "name": "AWS_S3_BUCKET", "value": "countrify-prod-assets" },
        { "name": "AWS_S3_PUBLIC_BASE_URL", "value": "https://countrify-prod-assets.s3.us-east-1.amazonaws.com" },
        { "name": "DB_HOST", "value": "citify-prod-db.cyhi4wiiax9v.us-east-1.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_NAME", "value": "citify" },
        { "name": "DB_USER", "value": "countrify_app" },
        { "name": "DB_SSL", "value": "require" },
        { "name": "OPENROUTER_MODEL", "value": "openai/gpt-4o-mini" },
        { "name": "VAPID_MAILTO", "value": "mailto:admin@countrify.com.ar" },
        { "name": "NEXT_PUBLIC_VAPID_PUBLIC_KEY", "value": "BGcQUrYQM6K5SVP2_UKQLImOX_vkAJLC52dzt1C0g4yv6RQNwPz6Mfp3m3-P3vPvIHIf8P-aYvrBO4vGaZV28IQ" },
        { "name": "NEXT_PUBLIC_SITE_URL", "value": "https://countrify.com.ar" },
        { "name": "NEXT_PUBLIC_APP_BASE_URL", "value": "https://countrify.com.ar" }
      ],
      "secrets": [
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:351885857894:secret:countrify/prod/db-password-GStDDw" },
        { "name": "APP_SESSION_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-1:351885857894:secret:countrify/prod/app-session-secret-BPJSId" },
        { "name": "VAPID_PRIVATE_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:351885857894:secret:countrify/prod/vapid-private-key-ZOkr9t" },
        { "name": "OPENROUTER_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:351885857894:secret:countrify/prod/openrouter-api-key-4w3lHV" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/countrify-prod-web",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "tags": [
    { "key": "Project", "value": "Countrify" },
    { "key": "Env", "value": "prod" }
  ]
}
